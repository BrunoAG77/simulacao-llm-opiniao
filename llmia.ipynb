        "\n",
        "    y_llm = y_llm.apply(lambda x: x if x in opcoes_nonull else None)\n",
        "\n",
        "    mask = y_real.notnull() & y_llm.notnull()\n",
        "\n",
        "    y_real = y_real[mask]\n",
        "    y_llm = y_llm[mask]\n",
        "\n",
        "    y_real_percent = y_real.value_counts(normalize=True)\n",
